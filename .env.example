AGENT_NAME=Barretao
WAKE_NAME=barretão
AGENT_DB_PATH=agent_memory.db

# provedor de LLM: ollama | openai | gemini | openrouter | groq
LLM_PROVIDER=ollama
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.7

# opcionais quando usar provider específico
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

MULTI_MODEL_ENABLED=false
MULTI_MODEL_MODE=primary_fallback
OLLAMA_MODEL_SECONDARY=
OLLAMA_BASE_URL_SECONDARY=
AUTO_USE_ALL_MODELS=false
WOL_DEFAULT_MAC=
WOL_BROADCAST=255.255.255.255
WOL_PORT=9

# voz
AUTO_SPEAK=true
VOICE_LANGUAGE=pt-BR
STT_ENGINE=sphinx
TTS_RATE=165
TTS_VOLUME=1.0
TTS_VOICE_HINT=pt-br
TTS_HUMANIZED=true
TTS_PROVIDER=edge
EDGE_TTS_VOICE=pt-BR-FranciscaNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
ROUTINE_LEARNING=true
PROACTIVE_MODE=true
PROACTIVE_MIN_COUNT=2

# discord
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_TRIGGER=!barretao
DISCORD_CHANNEL_IDS=

# briefing diário
USER_CITY=São Paulo
USER_COUNTRY=BR
AUTO_CITY_BY_IP=true
FORCE_CHROME=true
CHROME_PATH=

# hub multi-dispositivos
HUB_API_TOKEN=troque_este_token
HUB_HOST=0.0.0.0
HUB_PORT=8787
PUBLIC_TUNNEL=false

# persona (estilo de resposta)
PERSONA_MODE=default
PERSONA_HUMOR=medio
